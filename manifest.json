{
  "manifest_version": 3,
  "name": "Roam",
  "version": "0.1.0",
  "description": "Roam, powered by Skyscanner — passive travel intent detection",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.tiktok.com/*",
        "https://www.instagram.com/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Roam"
  }
}
