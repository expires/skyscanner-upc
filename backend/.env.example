# --- Backend Environment Variables ---
# Copy this file to .env and fill in your actual credentials

# 1. Gemini API Key (Required for destination detection and NLP summary)
GEMINI_API_KEY="your_gemini_api_key_here"

# 2. Skyscanner API Key (Required for live flight search)
SKYSCANNER_API_KEY="your_skyscanner_api_key_here"

# 3. MongoDB Connection String (Required for saving engagement events and intent scores)
# Example: mongodb+srv://<username>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI="your_mongodb_connection_string_here"

# --- Optional Configurations ---

# Server Port (Defaults to 3000)
# PORT=3000

# Gemini Model to use (Defaults to gemma-3-27b-it)
# GEMINI_MODEL="gemma-3-27b-it"

# Power BI Streaming Push URLs (V5 Feature)
# POWER_BI_EVENTS_URL="https://api.powerbi.com/beta/..."
# POWER_BI_SCORES_URL="https://api.powerbi.com/beta/..."
