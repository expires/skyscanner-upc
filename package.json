{
  "name": "roam-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "extension",
    "backend"
  ],
  "scripts": {
    "server": "npm run dev --workspace=backend",
    "start:backend": "npm run start --workspace=backend",
    "build:extension": "npm run build --workspace=roam-extension",
    "build:backend": "npm run build --workspace=backend",
    "build": "npm run build --workspaces",
    "watch:extension": "npm run watch --workspace=roam-extension"
  }
}
